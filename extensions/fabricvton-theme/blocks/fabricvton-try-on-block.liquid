{% liquid
  assign product_title = product.title | default: 'This product'
  assign featured_media = product.featured_media | default: product.featured_image
  assign featured_image_url = ''
  assign container_id = 'fabricvton-btn-' | append: block.id

  if featured_media
    assign featured_image_url = featured_media | image_url: width: 1200
  endif
%}

{{ 'fabricvton-app-embed.css' | asset_url | stylesheet_tag }}
{{ 'fabricvton-block.css' | asset_url | stylesheet_tag }}

<div
  id="{{ container_id }}"
  class="fabricvton-block"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product_title | escape }}"
  data-product-image="{{ featured_image_url }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%} ── Inline Try-On button ──────────────────────────── {%- endcomment -%}
  <button
    type="button"
    class="fabricvton-block__btn"
    aria-controls="{{ container_id }}-modal"
    aria-expanded="false"
  >
    <svg class="fabricvton-block__btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M15 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9l-6-6z"/>
      <path d="M15 3v6h6"/>
      <circle cx="10" cy="14" r="2"/>
      <path d="m20 21-3.1-3.1"/>
    </svg>
    {{ block.settings.button_label }}
  </button>

  {%- comment -%} ── Modal (same two-step flow as embed block) ─────── {%- endcomment -%}
  <div
    id="{{ container_id }}-modal"
    class="fabricvton-try-on__modal"
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="{{ container_id }}-title"
  >
    <div class="fabricvton-try-on__backdrop" data-close-modal></div>

    <div class="fabricvton-try-on__panel" role="document">

      {%- comment -%} ── Modal header ─────────────────────────────────── {%- endcomment -%}
      <div class="fabricvton-try-on__header">
        <div class="fabricvton-try-on__header-brand">
          <span class="fabricvton-try-on__eyebrow">Fabric VTON</span>
          <h2 id="{{ container_id }}-title" class="fabricvton-try-on__title">
            See how it looks on you
          </h2>
        </div>
        <button
          type="button"
          class="fabricvton-try-on__close"
          aria-label="Close try-on modal"
          data-close-modal
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      {%- comment -%} ── Step 1: Upload ─────────────────────────────────── {%- endcomment -%}
      <div class="fabricvton-try-on__step fabricvton-try-on__step--upload" data-step="upload">
        <div class="fabricvton-try-on__step-body">

          <div class="fabricvton-try-on__upload-col">
            <label class="fabricvton-try-on__dropzone" for="{{ container_id }}-upload" data-dropzone>
              <input
                id="{{ container_id }}-upload"
                class="fabricvton-try-on__input"
                type="file"
                accept="image/png,image/jpeg,image/webp"
              >
              <div class="fabricvton-try-on__dropzone-idle" data-dropzone-idle>
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" aria-hidden="true">
                  <rect x="4" y="4" width="40" height="40" rx="10" stroke-width="2.5" stroke-dasharray="6 4"/>
                  <path d="M24 16v16m-8-8 8-8 8 8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <strong>{{ block.settings.upload_label }}</strong>
                <span>PNG, JPG or WEBP · Max 10 MB</span>
              </div>
              <img
                class="fabricvton-try-on__upload-thumb"
                alt="Your uploaded photo"
                hidden
                data-upload-thumb
              >
            </label>
            <p class="fabricvton-try-on__product-context">
              Garment: <strong>{{ product_title }}</strong>
            </p>
          </div>

          <div class="fabricvton-try-on__tips-col">
            <p class="fabricvton-try-on__description">Upload a clear, front-facing photo and our AI will show you how this garment looks on you.</p>
            <ul class="fabricvton-try-on__tips">
              <li>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.707-9.293a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4Z" clip-rule="evenodd"/></svg>
                Use a clear, front-facing full-body photo
              </li>
              <li>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.707-9.293a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4Z" clip-rule="evenodd"/></svg>
                Good lighting gives best results
              </li>
              <li>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.707-9.293a1 1 0 0 0-1.414-1.414L9 10.586 7.707 9.293a1 1 0 0 0-1.414 1.414l2 2a1 1 0 0 0 1.414 0l4-4Z" clip-rule="evenodd"/></svg>
                Photo is processed privately &amp; never stored
              </li>
            </ul>
            <div class="fabricvton-try-on__actions">
              <button type="button" class="fabricvton-try-on__secondary" data-close-modal>Cancel</button>
              <button type="button" class="fabricvton-try-on__primary" disabled data-primary-action>
                Generate Try-On
              </button>
            </div>
          </div>

        </div>
      </div>

      {%- comment -%} ── Step 2: Generating + Result ───────────────────── {%- endcomment -%}
      <div class="fabricvton-try-on__step fabricvton-try-on__step--result" data-step="result" hidden>

        <div class="fabricvton-try-on__generating" data-generating hidden>
          <div class="fabricvton-try-on__spinner" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
          <p class="fabricvton-try-on__generating-label">AI is styling your look…</p>
          <p class="fabricvton-try-on__generating-sub">This usually takes 10–25 seconds</p>
        </div>

        <div class="fabricvton-try-on__comparison" data-comparison>
          <div class="fabricvton-try-on__comparison-panel">
            <div class="fabricvton-try-on__comparison-label">
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z"/></svg>
              Your Photo
            </div>
            <div class="fabricvton-try-on__comparison-frame">
              <img class="fabricvton-try-on__comparison-img" data-user-photo alt="Your uploaded photo">
            </div>
          </div>
          <div class="fabricvton-try-on__comparison-divider" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          </div>
          <div class="fabricvton-try-on__comparison-panel fabricvton-try-on__comparison-panel--result">
            <div class="fabricvton-try-on__comparison-label fabricvton-try-on__comparison-label--ai">
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M15.98 1.804a1 1 0 0 0-1.96 0l-.24 1.192a1 1 0 0 1-.784.785l-1.192.238a1 1 0 0 0 0 1.962l1.192.238a1 1 0 0 1 .785.785l.238 1.192a1 1 0 0 0 1.962 0l.238-1.192a1 1 0 0 1 .785-.785l1.192-.238a1 1 0 0 0 0-1.962l-1.192-.238a1 1 0 0 1-.785-.785l-.238-1.192ZM6.949 5.684a1 1 0 0 0-1.898 0l-.683 2.051a1 1 0 0 1-.633.633l-2.051.683a1 1 0 0 0 0 1.898l2.051.684a1 1 0 0 1 .633.632l.683 2.051a1 1 0 0 0 1.898 0l.683-2.051a1 1 0 0 1 .633-.633l2.051-.683a1 1 0 0 0 0-1.898l-2.051-.683a1 1 0 0 1-.633-.633L6.95 5.684ZM13.949 13.684a1 1 0 0 0-1.898 0l-.184.551a1 1 0 0 1-.632.633l-.551.183a1 1 0 0 0 0 1.898l.551.183a1 1 0 0 1 .633.633l.183.551a1 1 0 0 0 1.898 0l.184-.551a1 1 0 0 1 .632-.633l.551-.183a1 1 0 0 0 0-1.898l-.551-.184a1 1 0 0 1-.633-.632l-.183-.551Z"/></svg>
              AI Try-On Result
            </div>
            <div class="fabricvton-try-on__comparison-frame fabricvton-try-on__comparison-frame--result">
              <img class="fabricvton-try-on__comparison-img fabricvton-try-on__comparison-img--result" data-result-photo alt="AI try-on result" hidden>
              <div class="fabricvton-try-on__result-placeholder" data-result-placeholder>
                <div class="fabricvton-try-on__result-shimmer"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="fabricvton-try-on__result-actions">
          <button type="button" class="fabricvton-try-on__secondary" data-retry-action>← Try another photo</button>
          <a class="fabricvton-try-on__primary fabricvton-try-on__primary--link" href="{{ product.url }}" data-cart-link>Add to Cart</a>
        </div>

      </div>

    </div>
  </div>

</div>

<script src="{{ 'fabricvton-block.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Fabric VTON – Try On",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Try On"
    },
    {
      "type": "text",
      "id": "upload_label",
      "label": "Upload label",
      "default": "Click or drag a photo here"
    }
  ]
}
{% endschema %}
